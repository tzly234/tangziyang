---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
import { siteConfig } from '../config';
import { getCollection, render } from 'astro:content';

const aboutEntries = await getCollection('about');
const about = aboutEntries[0];

let Content;
if (about) {
  const rendered = await render(about);
  Content = rendered.Content;
}
---

<BaseLayout title={about?.data.title + ' - ' + siteConfig.title || 'About - ' + siteConfig.title}>
  <Navigation />

  <main class="container" style="padding-top: 6rem;">
    <article class="about">
      {Content && <Content />}
    </article>
  </main>

  <Footer />
</BaseLayout>

<style>
  .about {
    max-width: 600px;
    padding: 2rem 0;
  }
</style>

<style is:global>
  .about h1 {
    margin-bottom: 1.5rem;
  }

  .about h2 {
    margin-top: 2rem;
    margin-bottom: 1rem;
  }

  .about ul {
    list-style: disc;
    padding-left: 1.5rem;
    margin-bottom: 1.5rem;
  }

  .about li {
    color: var(--text-secondary);
    margin-bottom: 0.5rem;
  }
</style>
